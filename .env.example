# ── SMTP 凭证 ──
# 替换为你的邮箱和 SMTP 授权码
# SMTP_USER=your_email@qq.com
# SMTP_PASS=your_auth_code
# MAIL_TO=recipient@example.com

# ── SMTP 服务器 ──
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465

# ── 报告数量 ──
# 控制每份报告获取多少热门仓库，默认 20
# TRENDING_LIMIT=20

# ── 天数覆盖 ──
# 设置后覆盖 --range 参数，往前倒推 N 天
# TRENDING_DAYS=14

# ── 报告持久化路径（默认：项目目录下 .reports/）──
# REPORT_DIR=${HOME}/github_trending_reports

# ── 时间范围: daily / weekly / monthly / yearly ──
# TRENDING_RANGE=daily

# ── AI Agent 配置 ──
# AI agent: pi / omp / opencode（默认 pi）
# AI_AGENT=pi
# AI agent 超时秒数（默认 180）
# AI_AGENT_TIMEOUT=180
# 覆盖报告 footer 中的模型名称（默认自动检测 pi 配置）
# AI_MODEL_NAME=
